# Twelve Data API key — DO NOT commit the real value.
# Recommended: store in macOS keychain instead of this file.
#
#   security add-generic-password -s twelvedata -a "$USER" -w 'YOUR_KEY'
#   npm run start
#
# Fallback (less secure — file lives on disk):
#   TWELVEDATA_KEY=your_key_here node server/proxy.js
